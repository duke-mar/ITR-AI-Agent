# ============================================================
# LLM 配置（必填）
# 兼容所有 OpenAI 格式 API：DeepSeek、通义、Moonshot、OpenAI
# ============================================================
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ============================================================
# RAG 配置（可选，使用时取消注释并填写）
# ============================================================
# RAG_ENABLED=true
# RAG_BASE_URL=https://your-rag-service.com/api
# RAG_API_KEY=your-rag-api-key
# RAG_TOP_K=3

# ============================================================
# 数据库配置（可选，使用时取消注释并填写）
# SQLite 示例（本地开发）
# DB_ENABLED=true
# DB_URL=sqlite:///data/chat_sessions.db

# PostgreSQL 示例（生产环境）
# DB_ENABLED=true
# DB_URL=postgresql+asyncpg://user:password@localhost:5432/itr_db

# ============================================================
# 应用配置
# ============================================================
APP_NAME=ITR-智能客服
APP_DEBUG=false
APP_PORT=8000

# 会话配置
MAX_INFO_COLLECTION_ROUNDS=3
MAX_TOTAL_ROUNDS=10
